# Example environment file (safe to commit)
# Copy values into .env and set your own API key.
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional alias used by current code path.
LLM_API_KEY=your_openai_api_key_here

# Model tiers
MODEL_TIER_FAST=gpt-4o-mini
MODEL_TIER_BALANCED=gpt-4.1-mini
MODEL_TIER_POWERFUL=gpt-4.1

# Logging behavior
ENVIRONMENT=production
LOG_FORMAT=json
